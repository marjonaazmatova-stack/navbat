# NavbatHub muhit o'zgaruvchilari
# Production'ga deploy qilishdan oldin bu fayldan nusxa olib .env nomi bilan saqlang
# va o'zingiz uchun moslang

# Django sirli kalit - random uzun satr (production'da ALMASHTIRING!)
SECRET_KEY=django-insecure-CHANGE-ME-IN-PRODUCTION-x7k9m2p4q8w3e6r5t1y

# Production'da False qiling
DEBUG=True

# Vergul bilan ajratilgan ruxsat etilgan hostlar
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app,.onrender.com,.fly.dev

# Saytning to'liq URL'i (QR-kodlar uchun)
SITE_URL=http://localhost:8000

# Ma'lumotlar bazasi (default SQLite, production'da Postgres ham mumkin)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3
